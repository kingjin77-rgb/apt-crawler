# 공공데이터포털 API 키 (https://www.data.go.kr 가입 후 발급)
PUBLIC_DATA_API_KEY=YOUR_API_KEY_HERE

# DB 경로 (기본값: data/apt_crawler.db)
DB_PATH=data/apt_crawler.db

# 수집 주기 (분, 기본 60분)
CRAWL_INTERVAL_MINUTES=60

# 출력 디렉토리
OUTPUT_DIR=data/output

# 요청 간격 (초, 서버 부하 방지)
REQUEST_DELAY=1.5

# Notion 연동 (https://www.notion.so/my-integrations 에서 발급)
NOTION_TOKEN=ntn_YOUR_TOKEN_HERE
NOTION_DATABASE_ID=YOUR_DATABASE_ID_HERE
